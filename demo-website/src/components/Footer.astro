---
import { getRepoStats, formatCount } from '../lib/github';

const GH_URL = 'https://github.com/brendangooden/ms-teams-sharepoint-downloader';
const CHROME_URL = 'https://chromewebstore.google.com/detail/ms-teams-transcript-downl/hmljlkhcebhkkhbbafiheolbneecoinp';
const year = new Date().getFullYear();
const { stars } = await getRepoStats();
---
<footer class="hairline">
  <div class="mx-auto max-w-[1280px] px-6 lg:px-10 py-14">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 mb-14">
      <div>
        <p class="section-num mb-4">product</p>
        <ul class="space-y-2 text-[13px]">
          <li><a href={CHROME_URL} target="_blank" rel="noopener" class="lnk">Chrome Web Store</a></li>
          <li><a href="#features" class="lnk">Features</a></li>
          <li><a href="#screenshots" class="lnk">Screenshots</a></li>
          <li><a href="#privacy" class="lnk">Privacy</a></li>
        </ul>
      </div>
      <div>
        <p class="section-num mb-4">project</p>
        <ul class="space-y-2 text-[13px]">
          <li>
            <a href={GH_URL} target="_blank" rel="noopener" class="lnk inline-flex items-center gap-1.5">
              <span>Source</span>
              <span
                class="inline-flex items-center gap-1 text-yellow"
                aria-label={stars > 0 ? `${stars} stars` : undefined}
                data-gh-stars-badge
                hidden={stars === 0}
              >
                <svg width="10" height="10" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/></svg>
                <span class="text-fg-dim tabular-nums" data-gh-stars-count>{formatCount(stars)}</span>
              </span>
            </a>
          </li>
          <li><a href={`${GH_URL}/issues`} target="_blank" rel="noopener" class="lnk">Issues</a></li>
          <li><a href={`${GH_URL}/blob/main/LICENSE`} target="_blank" rel="noopener" class="lnk">License (MIT)</a></li>
          <li><a href={`${GH_URL}/releases`} target="_blank" rel="noopener" class="lnk">Releases</a></li>
        </ul>
      </div>
      <div>
        <p class="section-num mb-4">privacy</p>
        <ul class="space-y-2 text-[13px]">
          <li><a href="#privacy" class="lnk">No tracking</a></li>
          <li><a href="#privacy" class="lnk">Local-only</a></li>
          <li><a href={`${GH_URL}#privacy--security`} target="_blank" rel="noopener" class="lnk">Tech details</a></li>
        </ul>
      </div>
      <div>
        <p class="section-num mb-4">about</p>
        <ul class="space-y-2 text-[13px]">
          <li class="text-fg-dim">Built by <a href="https://github.com/brendangooden" target="_blank" rel="noopener" class="lnk">Brendan Gooden</a></li>
          <li class="text-fg-dim">Not affiliated with Microsoft</li>
          <li class="text-fg-dim">Not affiliated with Google</li>
        </ul>
      </div>
    </div>

    <!-- spec-sheet readout -->
    <div class="border border-border">
      <div class="grid grid-cols-2 md:grid-cols-5 text-[11px]">
        <div class="px-4 py-3 border-r border-b md:border-b-0 border-border">
          <span class="text-fg-faint block">version</span>
          <span class="text-fg">v1.4.0</span>
        </div>
        <div class="px-4 py-3 border-r border-b md:border-b-0 border-border">
          <span class="text-fg-faint block">license</span>
          <span class="text-fg">MIT</span>
        </div>
        <div class="px-4 py-3 border-r border-b md:border-b-0 border-border">
          <span class="text-fg-faint block">manifest</span>
          <span class="text-fg">v3</span>
        </div>
        <div class="px-4 py-3 border-r border-border">
          <span class="text-fg-faint block">browsers</span>
          <span class="text-fg">chrome · edge</span>
        </div>
        <div class="px-4 py-3 border-border col-span-2 md:col-span-1">
          <span class="text-fg-faint block">built with</span>
          <span class="text-fg">astro · tailwind · ❤</span>
        </div>
      </div>
    </div>

    <div class="ascii-rule mt-8 select-none">
      ────────────────────────────────────────────────────────────────────
    </div>

    <p class="mt-6 text-[11px] text-fg-faint">
      © {year} &mdash; Use responsibly. Respect copyright. Respect the people in
      the recordings you save.
    </p>
  </div>
</footer>
