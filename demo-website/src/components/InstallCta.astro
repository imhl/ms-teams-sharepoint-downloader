---
const CHROME_URL = 'https://chromewebstore.google.com/detail/ms-teams-transcript-downl/hmljlkhcebhkkhbbafiheolbneecoinp';
const GH_URL = 'https://github.com/brendangooden/ms-teams-sharepoint-downloader';
---
<section id="install" class="hairline bg-bg-elev">
  <div class="mx-auto max-w-[1280px] px-6 lg:px-10 py-24 lg:py-32">
    <div class="text-center max-w-3xl mx-auto">
      <p class="section-num">07 / install</p>
      <h2 class="mt-5 font-display text-[clamp(3rem,7vw,5.5rem)] leading-[0.95] tracking-[-0.025em]">
        Get it. <span class="italic text-red">Now.</span>
      </h2>
      <p class="mt-6 text-fg-dim text-[14px] max-w-lg mx-auto leading-[1.65]">
        One click from the Chrome Web Store. Or clone the repo and load unpacked
        in <span class="kbd">chrome://extensions</span> if you want to read the
        code first.
      </p>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
        <a href={CHROME_URL} target="_blank" rel="noopener" class="btn btn-primary text-[14px] py-3 px-5">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0a12 12 0 0 1 10.39 6H12a6 6 0 0 0-5.2 9L2.46 7.5A12 12 0 0 1 12 0Zm-3 12a3 3 0 1 1 6 0 3 3 0 0 1-6 0Zm10.39 0A11.94 11.94 0 0 1 12 24l4.34-7.5a6 6 0 0 0 2.97-7.5h.08Zm-7.42 4.91L7.65 9.4A12 12 0 0 0 12 24a12 12 0 0 0 0-12c.4 0 .8.03 1.18.09l-2.21 4.82Z"/></svg>
          <span>install on chrome &amp; edge</span>
        </a>
        <a href={GH_URL} target="_blank" rel="noopener" class="btn text-[14px] py-3 px-5">
          <span>build from source</span>
          <svg width="13" height="13" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M3 9 9 3M9 3H4m5 0v5" stroke="currentColor" stroke-width="1.4" stroke-linecap="square"/></svg>
        </a>
      </div>

      <p class="mt-8 text-[11px] text-fg-faint">
        v1.3.0 · MIT · 22 KB unpacked · works on
        <span class="kbd">teams.microsoft.com</span>,
        <span class="kbd">teams.cloud.microsoft</span>,
        <span class="kbd">*.sharepoint.com</span>
      </p>
    </div>
  </div>
</section>
