---
import { getRepoStats, formatCount } from '../lib/github';

const CHROME_URL = 'https://chromewebstore.google.com/detail/ms-teams-transcript-downl/hmljlkhcebhkkhbbafiheolbneecoinp';
const GH_URL = 'https://github.com/brendangooden/ms-teams-sharepoint-downloader';
const { stars } = await getRepoStats();
---
<header class="hairline-b sticky top-0 z-50 backdrop-blur" style="background: color-mix(in srgb, var(--bg) 88%, transparent);">
  <div class="mx-auto max-w-[1280px] px-6 lg:px-10">
    <div class="flex items-center justify-between h-14">
      <a href="#top" class="flex items-center gap-3 group">
        <span class="inline-flex items-center justify-center w-7 h-7 border border-border-strong" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M7 1v8m-3-3 3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="square"/>
            <rect x="2" y="11" width="10" height="1.5" fill="currentColor"/>
          </svg>
        </span>
        <span class="text-[13px] tracking-tight">
          <span class="text-fg-dim">teamsvideo</span><span class="text-fg">transcriptexporter</span><span class="text-fg-faint">.com</span>
        </span>
      </a>

      <nav class="hidden md:flex items-center gap-6 text-[12px] text-fg-dim">
        <a href="#problem" class="hover:text-fg transition-colors">why</a>
        <a href="#features" class="hover:text-fg transition-colors">features</a>
        <a href="#screenshots" class="hover:text-fg transition-colors">screenshots</a>
        <a href="#privacy" class="hover:text-fg transition-colors">privacy</a>
        <a href="#faq" class="hover:text-fg transition-colors">faq</a>
      </nav>

      <div class="flex items-center gap-2">
        <a
          href={GH_URL}
          target="_blank"
          rel="noopener"
          class="btn btn-ghost hidden sm:inline-flex"
          aria-label={stars > 0 ? `View on GitHub — ${stars} stars` : 'View on GitHub'}
          data-gh-link
        >
          <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38v-1.34c-2.23.48-2.7-1.07-2.7-1.07-.36-.93-.89-1.18-.89-1.18-.73-.5.05-.49.05-.49.81.06 1.23.83 1.23.83.72 1.22 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.66 7.66 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.74.54 1.48v2.2c0 .21.15.46.55.38A8 8 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/></svg>
          <span>github</span>
          <span class="text-fg-faint" aria-hidden="true" data-gh-stars-sep hidden={stars === 0}>·</span>
          <span class="inline-flex items-center gap-1 text-yellow" aria-hidden="true" data-gh-stars-badge hidden={stars === 0}>
            <svg width="10" height="10" viewBox="0 0 16 16" fill="currentColor"><path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/></svg>
            <span class="text-fg tabular-nums" data-gh-stars-count>{formatCount(stars)}</span>
          </span>
        </a>
        <a href={CHROME_URL} target="_blank" rel="noopener" class="btn btn-primary">
          <span>install</span>
          <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M3 9 9 3M9 3H4m5 0v5" stroke="currentColor" stroke-width="1.4" stroke-linecap="square"/></svg>
        </a>
      </div>
    </div>
  </div>
</header>
